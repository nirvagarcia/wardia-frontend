generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  name          String
  phone         String?
  passwordHash  String
  preferences   Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  passwordResets PasswordReset[]

  @@index([email])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Service {
  id              String   @id @default(cuid())
  userId          String
  name            String
  description     String?
  category        String
  iconUrl         String?
  amountValue     Float
  amountCurrency  String   @default("PEN")
  frequency       String
  nextPaymentDate DateTime
  status          String   @default("active")
  autoRenewal     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
}

model Credential {
  id                  String   @id @default(cuid())
  userId              String
  type                String   @default("bank")
  credentialName      String?
  description         String?
  bankName            String

  username            String?
  passwordEnc         String?

  cardName            String?
  cardNetwork         String?
  accountNumberEnc    String?
  cciEnc              String?
  expiryMonth         Int?
  expiryYear          Int?
  cvvEnc              String?
  accountType         String?

  cardholderName      String?
  creditLimitValue    Float?
  creditLimitCurrency String?
  cutoffDay           Int?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@index([userId, type])
}

model Transaction {
  id             String   @id @default(cuid())
  userId         String
  type           String
  status         String   @default("completed")
  amountValue    Float
  amountCurrency String   @default("PEN")
  description    String
  merchant       String?
  category       String
  date           DateTime
  notes          String?
  accountId      String?
  cardId         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([userId, date])
}
