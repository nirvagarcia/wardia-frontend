generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  name          String
  phone         String?
  passwordHash  String
  preferences   Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  passwordResets  PasswordReset[]
  billingPeriods  BillingPeriod[]
  planningBoards  PlanningBoard[]

  @@index([email])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Service {
  id              String   @id @default(cuid())
  userId          String
  name            String
  description     String?
  category        String
  iconUrl         String?
  amountValue     Float
  amountCurrency  String   @default("PEN")
  frequency       String
  nextPaymentDate DateTime
  status          String   @default("active")
  autoRenewal     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
}

model Credential {
  id                  String   @id @default(cuid())
  userId              String
  type                String   @default("bank")
  credentialName      String?
  description         String?
  bankName            String

  username            String?
  passwordEnc         String?

  cardName            String?
  cardNetwork         String?
  accountNumberEnc    String?
  cciEnc              String?
  expiryMonth         Int?
  expiryYear          Int?
  cvvEnc              String?
  accountType         String?

  cardholderName      String?
  creditLimitValue    Float?
  creditLimitCurrency String?
  cutoffDay           Int?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@index([userId, type])
}

model Transaction {
  id             String   @id @default(cuid())
  userId         String
  type           String
  status         String   @default("completed")
  amountValue    Float
  amountCurrency String   @default("PEN")
  description    String
  merchant       String?
  category       String
  date           DateTime
  notes          String?
  accountId      String?
  cardId         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([userId, date])
}

model BillingPeriod {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([userId, startDate])
}

model PlanningBoard {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  coverImage  String?
  order       Int      @default(0)
  archived    Boolean  @default(false)
  shareToken  String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lists PlanningList[]

  @@index([userId])
  @@index([userId, archived])
  @@index([shareToken])
}

model PlanningList {
  id          String   @id @default(cuid())
  boardId     String
  title       String
  description String?
  order       Int      @default(0)
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  board PlanningBoard  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  items PlanningItem[]

  @@index([boardId])
  @@index([boardId, archived])
}

model PlanningItem {
  id            String    @id @default(cuid())
  listId        String
  title         String
  description   String?
  imageUrl      String?
  priceValue    Float?
  priceCurrency String    @default("PEN")
  quantity      Int       @default(1)
  priority      String    @default("medium")
  status        String    @default("pending")
  tags          String[]
  notes         String?
  purchasedAt   DateTime?
  order         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  list  PlanningList      @relation(fields: [listId], references: [id], onDelete: Cascade)
  links PlanningItemLink[]

  @@index([listId])
  @@index([listId, status])
}

model PlanningItemLink {
  id        String @id @default(cuid())
  itemId    String
  label     String?
  url       String
  createdAt DateTime @default(now())

  item PlanningItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}
